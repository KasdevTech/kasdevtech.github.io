# ===== LLM (OpenAI-compatible endpoint) =====
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4.1-mini
OPENAI_BASE_URL=https://api.openai.com/v1

# ===== WordPress =====
WORDPRESS_SITE_URL=https://kasdevtech.com
WORDPRESS_USERNAME=
WORDPRESS_APP_PASSWORD=
WORDPRESS_DEFAULT_STATUS=publish
WORDPRESS_DEFAULT_CATEGORY=
PUBLISH_WORDPRESS=true

# ===== LinkedIn =====
# Create app + token with permissions to post on your profile or organization page.
LINKEDIN_ENABLED=true
LINKEDIN_ACCESS_TOKEN=
LINKEDIN_AUTHOR_URN=urn:li:person:xxxxxxxx
# Optional: if posting to company page use organization urn, e.g. urn:li:organization:123456

# ===== Scheduling =====
TIMEZONE=Asia/Kolkata
RUN_HOUR_24=19
RUN_MINUTE=0
POSTS_PER_RUN=2
LOOKBACK_HOURS=36

# ===== Topic targeting =====
TOPICS=AI,MCP,LangChain,LangGraph,LangGraph Studio,Azure AI,Azure Databricks,Microsoft Fabric,Anthropic,OpenAI,Google Cloud AI,AWS AI

# Optional extra RSS feeds (comma-separated)
EXTRA_RSS_FEEDS=

# Local output path when WordPress is disabled
LOCAL_OUTPUT_DIR=generated_posts

# ===== GitHub Pages Mirror (optional) =====
# Local path to your kasdevtech.github.io clone
GITHUB_PAGES_REPO_PATH=
# Directory inside repo for posts (Jekyll: _posts, Hugo: content/ai)
GITHUB_PAGES_POSTS_DIR=_posts
# If true, commit generated _posts markdown in that repo
GITHUB_PAGES_AUTO_COMMIT=false
# If true, push after commit
GITHUB_PAGES_AUTO_PUSH=false

# Optional persistent dedup state (recommended to store in target repo)
PUBLISHED_STATE_FILE=
